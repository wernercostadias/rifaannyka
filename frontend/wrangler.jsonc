{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "rifaannyka",
  "main": ".output/server/index.mjs",
  "compatibility_date": "2026-06-04",
  "compatibility_flags": ["nodejs_compat", "nodejs_compat_v2"],
  "assets": {
    "directory": ".output/public",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
