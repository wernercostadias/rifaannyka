ENVIRONMENT=local

# Aplicacao
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RESERVATION_MINUTES=15

# Banco de dados
# Opcional no ambiente local. Se vazio, o backend usa SQLite em backend/db.sqlite3.
DATABASE_URL=postgres://user:password@localhost:5432/rifa

# Alternativa com credenciais separadas
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rifa
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_SSLMODE=disable

# Frontend
NUXT_PUBLIC_API_BASE=http://127.0.0.1:8000/api/v1
NUXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
NUXT_PUBLIC_ENABLE_PAYMENT_SIMULATION=true

# Mercado Pago
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_NOTIFICATION_URL=
MERCADOPAGO_STATEMENT_DESCRIPTOR=RIFA ANNYKA
